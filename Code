#include <stdio.h>
#include <stdlib.h>

struct Node
{
    int data;
    struct Node *next;
};

void insertValue(struct Node **head, int value)
{
    struct Node *newNode;

    newNode = (struct Node*)malloc(sizeof(struct Node));

    if(newNode == NULL)
    {
        printf("Memory allocation failed\n");
        return;
    }

    newNode->data = value;
    newNode->next = *head;
    *head = newNode;

    printf("Value inserted\n");
}

void deleteAtStart(struct Node **head)
{
    struct Node *temp;

    if(*head == NULL)
    {
        printf("List is empty\n");
        return;
    }

    temp = *head;
    *head = temp->next;
    free(temp);

    printf("First node deleted\n");
}

void deleteByValue(struct Node **head, int target)
{
    struct Node *current, *previous;

    if(*head == NULL)
    {
        printf("List is empty\n");
        return;
    }

    current = *head;
    previous = NULL;

    if(current->data == target)
    {
        *head = current->next;
        free(current);
        printf("Node deleted\n");
        return;
    }

    while(current != NULL && current->data != target)
    {
        previous = current;
        current = current->next;
    }

    if(current == NULL)
    {
        printf("Value not found\n");
        return;
    }

    previous->next = current->next;
    free(current);

    printf("Node deleted\n");
}

void display(struct Node *head)
{
    if(head == NULL)
    {
        printf("List is empty\n");
        return;
    }

    printf("List: ");

    while(head != NULL)
    {
        printf("%d ", head->data);
        head = head->next;
    }

    printf("\n");
}

int main()
{
    struct Node *head = NULL;
    int choice, value;

    printf("Linked List Program\n");

    do
    {
        printf("\n1 Insert Value/s");
        printf("\n2 Delete First Value");
        printf("\n3 Delete By Value");
        printf("\n4 Display List ");
        printf("\n5 Exit");
        printf("\nEnter choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                printf("Enter value: ");
                scanf("%d",&value);
                insertValue(&head, value);
                break;

            case 2:
                deleteAtStart(&head);
                break;

            case 3:
                printf("Enter value to delete: ");
                scanf("%d", &value);
                deleteByValue(&head, value);
                break;

            case 4:
                display(head);
                break;

            case 5:
                printf("Program ended.");
                break;

            default:
                printf("Invalid choice\n");
        }

    } while(choice != 5);

    return 0;
}
